<%# new code here %>
<div class="navbar mb-5">
  <div class="container d-flex justify-content-between align-items-center">
    <%= link_to "Airbnb Clone", flats_path, class: "navbar-brand fw-bold text-danger" %>
    <%= link_to "Add Flat", new_flat_path, class: "btn btn-outline-danger btn-sm" %>
  </div>
</div>

<div class="container">
  <div class="row mb-5 justify-content-center">
    <div class="col-md-6">
      <%= form_with url: flats_path, method: :get, class: "d-flex gap-2" do |f| %>
        <%= f.text_field :query,
                        value: params[:query],
                        placeholder: "Find a flat...",
                        class: "form-control search-form-control" %>
        <%= f.submit "Search", class: "btn btn-airbnb" %>
      <% end %>
    </div>
  </div>

  <h2 class="mb-4">All our Flats</h2>

  <div class="row">
    <% @flats.each do |flat| %>
      <div class="col-12 col-sm-6 col-md-4">
        <%= link_to flat_path(flat), class: "text-decoration-none" do %>
          <div class="flat-card">
            <%= image_tag flat.picture_url, class: "flat-card-image" %>
            <div class="flat-card-content">
              <h3 class="flat-card-title text-dark"><%= flat.name %></h3>
              <p class="flat-card-address mb-1"><%= flat.address %></p>
              <div class="d-flex gap-3 flat-card-info">
                <span><i class="fa-solid fa-users"></i> <%= flat.number_of_guests %></span>
                <span><i class="fa-solid fa-euro-sign"></i> <%= flat.price_per_night %></span>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
