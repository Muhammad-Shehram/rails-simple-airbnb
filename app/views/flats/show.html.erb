<div class="container mt-5">
  <%= link_to "← Back to list", flats_path, class: "back-link mb-4 d-block" %>

  <div class="row">
    <div class="col-12">
      <h1 class="fw-bold"><%= @flat.name %></h1>
      <p class="text-muted"><%= @flat.address %></p>
    </div>
  </div>

  <%= image_tag @flat.picture_url, class: "flat-show-image" %>

  <div class="row mt-4">
    <div class="col-12 col-md-8">
      <h3>About this flat</h3>
      <p class="fs-5 text-secondary"><%= @flat.description %></p>
      <hr>
      <div class="d-flex gap-4">
        <%= link_to "Edit this flat", edit_flat_path(@flat), class: "btn btn-light border" %>
        <%= link_to "Remove", flat_path(@flat), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn btn-outline-danger" %>
      </div>
    </div>

    <div class="col-12 col-md-4">
      <div class="flat-show-card">
        <h4><strong>€<%= @flat.price_per_night %></strong> <small class="text-muted">/ night</small></h4>
        <hr>
        <p><i class="fa-solid fa-users me-2"></i> Up to <strong><%= @flat.number_of_guests %> guests</strong></p>
        <button class="btn btn-airbnb w-100 mt-3">Check availability</button>
      </div>
    </div>
  </div>
</div>
